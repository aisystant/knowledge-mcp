# Knowledge MCP — Environment Variables
# Copy to .dev.vars and fill in values

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/knowledge?sslmode=require

# OpenRouter API key (routes to openai/text-embedding-3-small + openai/gpt-4o-mini)
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key
